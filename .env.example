# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
LIFE_TELEGRAM_BOT_TOKEN=your-life-telegram-bot-token
WEBHOOK_URL=https://your-webhook-domain.example.com

# AI routing
# Allowed values: gemini, openrouter
PRIMARY_AI_PROVIDER=gemini
AI_FALLBACK_COOLDOWN_SECONDS=300

# Gemini
GEMINI_API_KEY=your-gemini-api-key

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Comma-separated model pools. The bot tries them in order, rotates after success,
# and falls through to the next model when one is unavailable for that capability.
OPENROUTER_MODELS_TEXT=openrouter/free,openrouter/auto
OPENROUTER_MODELS_VISION=google/gemma-3-27b-it:free,google/gemma-3-4b-it:free,openrouter/free,google/gemini-2.5-flash-preview
# Do not use openrouter/free for audio. Pick explicit audio-capable models.
OPENROUTER_MODELS_AUDIO=openrouter/auto,google/gemini-3-pro-preview,google/gemini-2.5-flash-preview-09-2025

# Storage
DATABASE_URL=postgresql://username:password@db-host:5432/database_name
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project",...}
LIFE_GOOGLE_CALENDAR_ID=your-shared-google-calendar-id
LIFE_REMINDER_TICK_TOKEN=change-me
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_WEBHOOK_MAX_REQUESTS_PER_IP=120
RATE_LIMIT_REMINDER_MAX_REQUESTS_PER_IP=12
RATE_LIMIT_TRUST_FORWARDED_FOR=true

# Bot defaults
DEFAULT_CURRENCY=IDR
DEFAULT_TIMEZONE=Asia/Jakarta
LOW_CONFIDENCE_THRESHOLD=0.8
